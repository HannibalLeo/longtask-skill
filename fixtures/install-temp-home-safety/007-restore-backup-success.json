{
  "case_id": "install-temp-home-restore-backup-success",
  "description": "Restore mode only accepts backup directories under codex-home/longtask-backups and restores backup payload.",
  "case_type": "temp_home_shell_script_case",
  "script_path": "scripts/uninstall-codex.sh",
  "setup": {
    "dirs": [
      "{BACKUP_ROOT}/r1"
    ],
    "symlinks": [
      {
        "path": "{TEMP_CODEX_HOME}/skills/codex-longtask",
        "target": "{SOURCE_DIR}/skills/codex-longtask"
      },
      {
        "path": "{TEMP_CODEX_HOME}/skills/codex-longtask-code",
        "target": "{SOURCE_DIR}/skills/codex-longtask-code"
      },
      {
        "path": "{BACKUP_ROOT}/r1/codex-longtask.bak",
        "target": "{TEMP_ROOT}/restored-foreign-a"
      },
      {
        "path": "{BACKUP_ROOT}/r1/codex-longtask-code.bak",
        "target": "{TEMP_ROOT}/restored-foreign-b"
      }
    ]
  },
  "args": [
    "--source-dir",
    "{SOURCE_DIR}",
    "--codex-home",
    "{TEMP_CODEX_HOME}",
    "--restore-backup",
    "{BACKUP_ROOT}/r1"
  ],
  "real_home_probes": [
    "{REAL_CODEX_HOME}/skills/codex-longtask",
    "{REAL_CODEX_HOME}/skills/codex-longtask-code",
    "{REAL_CODEX_HOME}/longtask-backups"
  ],
  "assert_real_home_unchanged": true,
  "expected": {
    "exit_code": 0,
    "transcript": {
      "codex_home": "{TEMP_CODEX_HOME}",
      "source_dir": "{SOURCE_DIR}",
      "action": "restore",
      "entries": [
        {
          "name": "codex-longtask",
          "status": "RESTORED_BACKUP",
          "target": "{TEMP_CODEX_HOME}/skills/codex-longtask",
          "backup": "{BACKUP_ROOT}/r1/codex-longtask.bak"
        },
        {
          "name": "codex-longtask-code",
          "status": "RESTORED_BACKUP",
          "target": "{TEMP_CODEX_HOME}/skills/codex-longtask-code",
          "backup": "{BACKUP_ROOT}/r1/codex-longtask-code.bak"
        }
      ],
      "next_verify_command": "bash scripts/run-fixtures.sh --group install-temp-home-safety"
    }
  },
  "assert_fs": {
    "path_absent": [
      "{BACKUP_ROOT}/r1/codex-longtask.bak",
      "{BACKUP_ROOT}/r1/codex-longtask-code.bak"
    ],
    "symlink_targets": [
      {
        "path": "{TEMP_CODEX_HOME}/skills/codex-longtask",
        "target": "{TEMP_ROOT}/restored-foreign-a"
      },
      {
        "path": "{TEMP_CODEX_HOME}/skills/codex-longtask-code",
        "target": "{TEMP_ROOT}/restored-foreign-b"
      }
    ]
  }
}
