      "fake-stderr-pty\n"
    ],
    "argv": [
      "exec",
      "--json",
      "--model",
      "gpt-5.5",
      "--sandbox",
      "workspace-write",
      "--skip-git-repo-check",
      "-c",
      "model_reasoning_effort=\"xhigh\"",
      "-c",
