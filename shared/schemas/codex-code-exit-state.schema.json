{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Code Exit State",
  "description": "Exit-state contract for codex-longtask-code Step 6 execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "writer_skill",
    "completed_at",
    "session_id",
    "handoff_manifest_path",
    "handoff_manifest_sha256",
    "overall_status",
    "first_blocked_phase",
    "blocked_reason",
    "phase_results",
    "decision_records",
    "model_requests",
    "base_sha_before_phases",
    "head_sha_after_phases",
    "phase_commit_chain",
    "preserved_phase_commits",
    "resume_default_command",
    "safe_path_recovery_command",
    "plan_repair_command",
    "review_retry_command",
    "human_override_instructions",
    "review_handoff"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "writer_skill": {
      "type": "string",
      "const": "codex-longtask-code"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "handoff_manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "handoff_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "overall_status": {
      "$ref": "common-enums.schema.json#/$defs/final_status"
    },
    "first_blocked_phase": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^P[0-9]+$"
        },
        {
          "type": "null"
        }
      ]
    },
    "blocked_reason": {
      "anyOf": [
        {
          "$ref": "common-enums.schema.json#/$defs/blocked_reason"
        },
        {
          "type": "null"
        }
      ]
    },
    "phase_results": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^P[0-9]+$": {
          "$ref": "#/$defs/phase_result"
        }
      },
      "additionalProperties": false
    },
    "decision_records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision_record"
      }
    },
    "model_requests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model_request"
      }
    },
    "wrapper_mode_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "base_sha_before_phases": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "head_sha_after_phases": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "phase_commit_chain": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/phase_commit"
      }
    },
    "preserved_phase_commits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/phase_commit"
      }
    },
    "resume_default_command": {
      "type": "string",
      "minLength": 1
    },
    "safe_path_recovery_command": {
      "type": "string",
      "minLength": 1
    },
    "plan_repair_command": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "review_retry_command": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "human_override_instructions": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "review_handoff": {
      "$ref": "#/$defs/review_handoff"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "ALL_PASS"
          }
        }
      },
      "then": {
        "properties": {
          "first_blocked_phase": {
            "type": "null"
          },
          "blocked_reason": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "PARTIAL_PASS"
          }
        }
      },
      "then": {
        "properties": {
          "first_blocked_phase": {
            "type": "string",
            "pattern": "^P[0-9]+$"
          },
          "blocked_reason": {
            "$ref": "common-enums.schema.json#/$defs/blocked_reason"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "overall_status": {
            "const": "REVIEW_FAIL"
          }
        }
      },
      "then": {
        "properties": {
          "blocked_reason": {
            "$ref": "common-enums.schema.json#/$defs/blocked_reason"
          }
        }
      }
    }
  ],
  "$defs": {
    "phase_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_status",
        "goal",
        "source_requirements",
        "changed_files",
        "diff_stat",
        "retry_count",
        "verifier_json_paths",
        "parent_commit",
        "commit_sha",
        "started_at",
        "completed_at"
      ],
      "properties": {
        "phase_status": {
          "type": "string",
          "enum": [
            "PASS",
            "REVIEW_FAIL",
            "BLOCKED"
          ]
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "source_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "diff_stat": {
          "type": "string",
          "minLength": 1
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "verifier_json_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "parent_commit": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "commit_sha": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "phase_commit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_id",
        "commit_sha"
      ],
      "properties": {
        "phase_id": {
          "type": "string",
          "pattern": "^P[0-9]+$"
        },
        "commit_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        }
      }
    },
    "decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decided_by",
        "at",
        "summary"
      ],
      "properties": {
        "decided_by": {
          "type": "string",
          "enum": [
            "codex-internal",
            "claude"
          ]
        },
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "decision_id": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "model_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "requested",
        "actual"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "requested": {
          "type": "string",
          "minLength": 1
        },
        "actual": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        },
        "model_degraded": {
          "type": "boolean"
        }
      }
    },
    "review_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_skill",
        "review_entrypoint_command",
        "required_inputs",
        "handoff_reason",
        "hint"
      ],
      "properties": {
        "reviewer_skill": {
          "type": "string",
          "const": "claude-longtask-review"
        },
        "review_entrypoint_command": {
          "type": "string",
          "minLength": 1
        },
        "required_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "handoff_reason": {
          "type": "string",
          "enum": [
            "codex_step6_all_pass",
            "codex_step6_partial_pass",
            "codex_step6_review_fail"
          ]
        },
        "hint": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
