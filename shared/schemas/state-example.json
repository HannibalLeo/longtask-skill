{
  "_comment": "Reference example for .longtask/state/{spec_basename}.json. See SKILL.md '## State file (v2 schema)' for the field table; this file is the long-form example previously embedded in SKILL.md. v0.5 layout: spec stage = one Codex sanity pass; plan stage = gstack autoplan review (the old roundtable / round-loop fields were removed).",

  "mode": "claude-autoplan",
  "spec_path": "...",
  "spec_sha256": "...",
  "input_path": "<source_spec_path>",
  "input_sha256": "<source_spec_sha256>",
  "input_shape": "source_spec | hybrid | plan_with_source | self_contained_plan",
  "classification_path": ".longtask/state/{spec_basename}/classification.json",

  "spec_sanity_skipped_reason": null,
  "spec_codex_sanity_path": ".longtask/state/{spec_basename}/spec-codex-sanity.json",
  "spec_codex_sanity_verdict": "CLEAN | NEEDS_REVISION",

  "implementation_plan_path": ".longtask/plans/{spec_basename}-implementation-plan.md",
  "implementation_plan_sha256": "...",
  "implementation_plan_post_review_sha256": "...",
  "autoplan_review_report_path": ".longtask/plans/{spec_basename}-implementation-plan.md#gstack-review-report",
  "autoplan_review_status": "DONE | DONE_WITH_CONCERNS | BLOCKED | NEEDS_CONTEXT",
  "plan_integrity_review_path": ".longtask/state/{spec_basename}/plan-integrity.json",

  "model_requests": [
    {
      "role": "phase-worker-P1-r1",
      "requested": "gpt-5.5/xhigh",
      "actual": "gpt-5.4/high",
      "reason": "model unavailable",
      "model_degraded": true
    }
  ],

  "agents": [
    {
      "agent_id": "...",
      "role": "phase-sub-agent",
      "phase": "P1",
      "round": 0,
      "start_at": "...",
      "end_at": "..."
    }
  ],

  "claude_subagents": [
    {
      "id": "claude-<uuid>",
      "role": "spec-classifier",
      "model": "opus",
      "phase": "spec-stage",
      "start_at": "...",
      "end_at": "..."
    },
    {
      "id": "claude-<uuid>",
      "role": "plan-writer",
      "model": "opus",
      "phase": "plan-stage",
      "start_at": "...",
      "end_at": "..."
    }
  ],
  "codex_subagents": [
    {
      "id": "codex-<thread_id>",
      "role": "spec-codex-sanity",
      "model": "gpt-5.5",
      "reasoning": "xhigh",
      "start_at": "...",
      "end_at": "..."
    }
  ],
  "hybrid_gate_assignments": {
    "decision-review": ["claude-opus-primary", "codex-gpt5.5-secondary"],
    "plan-integrity-review": ["claude-opus-primary", "codex-gpt5.5-secondary"],
    "final-alignment-review": ["claude-opus-primary", "codex-gpt5.5-secondary"]
  },

  "phases": {
    "P1": {
      "status": "PASS | FAIL | BLOCKED_* | running",
      "rounds_used": 2,
      "verifier_json_paths": [
        ".longtask/state/.../verifier-P1-r1.json",
        ".longtask/state/.../verifier-P1-r2.json"
      ],
      "commit_sha": "...",
      "last_heartbeat": "ISO 8601",
      "heartbeats": [
        { "at": "...", "event": "phase-start" },
        { "at": "...", "event": "round-1-codex-worker-start" }
      ]
    }
  },

  "final_report_path": ".longtask/reports/.../final-report.md",
  "final_alignment_review_path": ".longtask/state/.../final-alignment.json"
}
